# connectkit's peerDependencies still cap React at 18.x (no published version
# allows React 19 yet), but Next.js 15 requires React 19. connectkit runs fine
# on React 19 in practice — the peer range is just stale. legacy-peer-deps lets
# local, CI, and Vercel installs resolve consistently. Revisit when connectkit
# publishes a React 19 peer.
legacy-peer-deps=true
